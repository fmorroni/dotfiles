[user]
	name = Franco Morroni
	mail = fmorroni@fu.do
	email = fmorroni@fu.do
	signingkey = 260FFCAA9EF86C78
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[difftool "nvimdiff"]
	cmd = nvim -f -d \"$LOCAL\" \"$REMOTE\"
[mergetool "nvimdiff"]
	cmd = nvim -f -d \"$LOCAL\" \"$MERGED\" \"$REMOTE\"
[alias]
	staash = stash --include-untracked
	rs = restore --staged
	res = restore
	tree = log --color --oneline --graph --decorate --all
[core]
	hooksPath = /home/franco/.config/git/hooks
	excludesfile = /home/franco/.gitignore.global
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
[merge]
	conflictStyle = zdiff3
